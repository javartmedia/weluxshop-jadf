{
    "name": "weluxshop/app",
    "description": "WeluxShop - Beauty Clinic & Skincare E-Commerce",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php database/migrations/migrate.php",
            "php database/seeders/seed.php"
        ]
    }
}
